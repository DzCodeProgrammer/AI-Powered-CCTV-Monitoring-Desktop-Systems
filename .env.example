# App
APP_NAME=Smart CCTV Face Recognition
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key

# Server
# Desktop app: 127.0.0.1 only | Web LAN host: 0.0.0.0
HOST=127.0.0.1
PORT=8000

# Database (Session 9)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=cctv_user
DB_PASSWORD=change-this-cctv-db-password
DB_NAME=smart_cctv
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password

# Camera (Session 9)
# Options: 0 (webcam), rtsp://..., or dahua (uses DAHUA_* below)
CAMERA_SOURCE=dahua

# Dahua IP CCTV (used when CAMERA_SOURCE=dahua)
DAHUA_USERNAME=admin
DAHUA_PASSWORD=change-this-dahua-password
DAHUA_HOST=192.168.100.135
DAHUA_PORT=554
DAHUA_CHANNEL=1
# 0 = main stream (HD) | 1 = sub stream (smoother on low-end laptops)
DAHUA_SUBTYPE=1

# Phase 2 — Dahua IPC FaceDetection events (snapManager.cgi, port 80)
# stream = RTSP live monitor only | event = event capture only | hybrid = both
CCTV_MODE=hybrid
DAHUA_EVENT_ENABLED=true
DAHUA_HTTP_PORT=80
DAHUA_EVENT_CHANNEL=0
DAHUA_EVENT_HEARTBEAT=5
DAHUA_EVENT_TIMEOUT=20
DAHUA_EVENT_RECONNECT=5

# Optional full RTSP override (takes priority over Dahua builder)
# RTSP_URL=rtsp://admin:password@192.168.100.135:554/cam/realmonitor?channel=1&subtype=0

# Face Recognition — low-latency defaults
FACE_MODEL=Facenet512
RECOGNITION_THRESHOLD=0.45
RECOGNITION_MARGIN=0.08
DETECTION_INTERVAL=1
RECOGNITION_INTERVAL=1
ATTENDANCE_INTERVAL=60

# Timezone (Indonesia WIB)
TIMEZONE=Asia/Jakarta

# Performance (Session 11) — i5 Gen4 / 8GB RAM / SSD
LOW_END_MODE=true
FRAME_SKIP=1
DETECTION_FRAME_SKIP=1
PROCESS_MAX_WIDTH=640
STREAM_MAX_WIDTH=640
JPEG_QUALITY=72
MAX_FACES_PER_FRAME=2
FACE_MIN_SIZE=36
DETECTION_LOW_LIGHT=true
FACE_DETECTOR=auto
YUNET_SCORE_THRESHOLD=0.45

# Paths
DATASET_DIR=datasets
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# Operations — schedule, cleanup (laptop / HDD friendly)
MONITOR_SCHEDULE_ENABLED=false
MONITOR_SCHEDULE_START=07:00
MONITOR_SCHEDULE_END=17:00
CLEANUP_ENABLED=true
LOG_RETENTION_DAYS=30
SCREENSHOT_RETENTION_DAYS=14
CLEANUP_INTERVAL_HOURS=24

# WhatsApp notifications (Fonnte — https://fonnte.com)
WA_NOTIFY_ENABLED=false
WA_API_TOKEN=
WA_ADMIN_PHONES=
WA_NOTIFY_UNKNOWN=true
WA_NOTIFY_ATTENDANCE=true

# Desktop app (Phase 2/3 — set automatically when running desktop_main.py)
DESKTOP_MODE=false
# Max width for live monitor display only; AI still uses PROCESS_MAX_WIDTH
DESKTOP_DISPLAY_MAX_WIDTH=640
# Recommended for desktop laptop: event-only Dahua capture, live monitor on-demand
# CCTV_MODE=event
# HOST=127.0.0.1

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SESSION_MAX_AGE=86400
