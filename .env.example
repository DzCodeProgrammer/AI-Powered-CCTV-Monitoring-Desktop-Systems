# App
APP_NAME=Smart CCTV Face Recognition
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key

# Server
# 127.0.0.1 = this PC only | 0.0.0.0 = LAN host (other devices on same network)
HOST=127.0.0.1
PORT=8000

# Database (Session 9)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=cctv_user
DB_PASSWORD=change-this-cctv-db-password
DB_NAME=smart_cctv
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password

# Camera (Session 9)
# Options: 0 (webcam), rtsp://..., or dahua (uses DAHUA_* below)
CAMERA_SOURCE=dahua

# Dahua IP CCTV (used when CAMERA_SOURCE=dahua)
DAHUA_USERNAME=admin
DAHUA_PASSWORD=change-this-dahua-password
DAHUA_HOST=192.168.100.135
DAHUA_PORT=554
DAHUA_CHANNEL=1
DAHUA_SUBTYPE=0

# Optional full RTSP override (takes priority over Dahua builder)
# RTSP_URL=rtsp://admin:password@192.168.100.135:554/cam/realmonitor?channel=1&subtype=0

# Face Recognition
FACE_MODEL=Facenet512
RECOGNITION_THRESHOLD=0.45
RECOGNITION_MARGIN=0.08
DETECTION_INTERVAL=30.0
RECOGNITION_INTERVAL=30.0
ATTENDANCE_INTERVAL=300

# Performance (Session 11) — i5 Gen4 / 8GB RAM / SSD
LOW_END_MODE=true
FRAME_SKIP=2
DETECTION_FRAME_SKIP=2
PROCESS_MAX_WIDTH=640
STREAM_MAX_WIDTH=960
JPEG_QUALITY=72
MAX_FACES_PER_FRAME=2
FACE_MIN_SIZE=36
DETECTION_LOW_LIGHT=true
FACE_DETECTOR=auto
YUNET_SCORE_THRESHOLD=0.45

# Paths
DATASET_DIR=datasets
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SESSION_MAX_AGE=86400
